        <TextBox x:Name="TextBox1" HorizontalAlignment="Center" Margin="0,217,0,0" TextWrapping="Wrap" Text="nope" VerticalAlignment="Top" Width="376" Height="67" TextChanged="TextBox1_TextChanged"/>
